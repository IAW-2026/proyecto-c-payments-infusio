## Clerk (compartido con todas las apps del grupo Infusio)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

## Base de datos (Prisma + PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

## Mercado Pago (modo Sandbox)
MERCADOPAGO_ACCESS_TOKEN=APP_USR-...

## API Key interna para autenticar llamadas entre servicios
PAYMENTS_API_KEY=your_secret_api_key

## URLs de los otros servicios del grupo
SELLER_APP_URL=http://localhost:3001
BUYER_APP_URL=http://localhost:3002
