## Clerk (compartido con todas las apps del grupo Infusio)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

## Base de datos (Prisma + PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

## Mercado Pago (modo Sandbox)
MERCADOPAGO_ACCESS_TOKEN=APP_USR-...

## API Key interna para autenticar llamadas entre servicios
PAYMENTS_API_KEY=your_secret_api_key

## API Key para el Analytics Dashboard
ANALYTICS_API_KEY=your_analytics_api_key

## API Key para el Control Panel (CRUD de órdenes)
CONTROL_API_KEY=your_control_panel_api_key

## URLs de los otros servicios del grupo
SELLER_APP_URL=https://proyecto-c-seller-infusio.vercel.app
SELLER_API_KEY=your_seller_api_key
BUYER_APP_URL=http://localhost:3002
